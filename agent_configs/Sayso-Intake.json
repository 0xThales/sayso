  "platform_settings": {
    "evaluation": {
      "criteria": [
        {
          "id": "all_fields_collected",
          "name": "All Fields Collected",
          "type": "prompt",
          "conversation_goal_prompt": "Mark as success if the agent collected answers for ALL required form fields before ending the conversation. Mark as failure if any required field was left unanswered or the conversation ended before all fields were addressed.",
          "use_knowledge_base": false,
          "scope": "conversation"
        },
        {
          "id": "answers_are_clear",
          "name": "Answers Are Clear",
          "type": "prompt",
          "conversation_goal_prompt": "Mark as success if the user provided clear, specific, and usable answers to all questions. Mark as failure if answers were vague, contradictory, or the agent accepted unclear responses without asking for clarification.",
          "use_knowledge_base": false,
          "scope": "conversation"
        },
        {
          "id": "form_completed",
          "name": "Form Completed",
          "type": "prompt",
          "conversation_goal_prompt": "Mark as success if the complete_form or submit_form tool was called and the conversation ended naturally with a closing message. Mark as failure if the user abandoned the conversation, the session timed out, or the form was never finalized.",
          "use_knowledge_base": false,
          "scope": "conversation"
        },
        {
          "id": "natural_conversation",
          "name": "Natural Conversation",
          "type": "prompt",
          "conversation_goal_prompt": "Mark as success if the conversation felt natural and human — the agent asked one question at a time, acknowledged answers briefly, and maintained a warm conversational tone without sounding robotic or repetitive. Mark as failure if the agent was awkward, asked multiple questions at once, repeated itself excessively, or ignored what the user said.",
          "use_knowledge_base": false,
          "scope": "conversation"
        },
        {
          "id": "user_not_frustrated",
          "name": "User Not Frustrated",
          "type": "prompt",
          "conversation_goal_prompt": "Mark as success if the user seemed comfortable and engaged throughout the conversation. Mark as failure if the user expressed frustration, confusion, impatience, asked to stop, or seemed annoyed with the agent.",
          "use_knowledge_base": false,
          "scope": "conversation"
        },
        {
          "id": "language_compliance",
          "name": "Language Compliance",
          "type": "prompt",
          "conversation_goal_prompt": "Mark as success if the agent responded exclusively in English throughout the entire conversation, regardless of what language the user spoke. Mark as failure if the agent switched to another language at any point.",
          "use_knowledge_base": false,
          "scope": "conversation"
        }
      ]
    },
