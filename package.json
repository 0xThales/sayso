{
  "name": "sayso",
  "private": true,
  "packageManager": "pnpm@10.14.0",
  "scripts": {
    "setup": "pnpm install",
    "start": "pnpm install && pnpm dev",
    "dev": "turbo dev",
    "dev:web": "turbo dev --filter=web",
    "dev:api": "turbo dev --filter=api",
    "dev:landing": "turbo dev --filter=landing",
    "build": "turbo build",
    "type-check": "turbo type-check",
    "clean": "rm -rf node_modules web/node_modules api/node_modules .turbo",
    "reset": "pnpm clean && pnpm install"
  },
  "devDependencies": {
    "turbo": "^2.9.6"
  }
}
